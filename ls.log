            "contentChanges": Array [
                Object {
                    "text": String("Glide.NetCommands = Glide.NetCommands or {}\r\nlocal commands = Glide.NetCommands\r\n\r\nlocal DebugNet = Glide.DebugNetwork\r\nlocal REMOVED = DebugNet.REMOVED\r\n\r\ncommands[Glide.CMD_CREATE_EXPLOSION] = function()\r\n    local pos = net.ReadVector()\r\n    local normal = net.ReadVector()\r\n    local explosionType = net.ReadUInt(2)\r\n\r\n    Glide.CreateExplosion(pos, normal, explosionType)\r\nend\r\n\r\ncommands[Glide.CMD_INCOMING_DANGER] = function()\r\n    local dangerType = net.ReadUInt(3)\r\n\r\n    if dangerType == Glide.DANGER_TYPE.LOCK_ON then\r\n        Glide.LockOnHandler:OnIncomingLockOn()\r\n    elseif dangerType == Glide.DANGER_TYPE.MISSILE then\r\n        Glide.LockOnHandler:OnIncomingMissile(net.ReadUInt(32))\r\n\r\n\r\n    end\r\nend\r\n\r\ncommands[Glide.CMD_VIEW_PUNCH] = function()\r\n    Glide.Camera:ViewPunch(net.ReadFloat())\r\nend\r\n\r\ncommands[Glide.CMD_SUSPENSION_STRESS_IMPACT] = function()\r\n    local vehicleId = net.ReadUInt(16)\r\n    local sevByte = net.ReadUInt(8)\r\n    local flags = net.ReadUInt(8)\r\n\r\n    local cam = Glide.Camera\r\n    if not (cam and cam.isActive) then return end\r\n\r\n    local vehicle = cam.vehicle\r\n    if not IsValid(vehicle) then return end\r\n    if vehicle:EntIndex() ~= vehicleId then return end\r\n\r\n    cam:OnSuspensionStressImpact(sevByte / 255, flags)\r\nend\r\n\r\ncommands[Glide.CMD_NOTIFY] = function()\r\n    local data = Glide.ReadTable()\r\n\r\n    if string.sub(data.text, 1, 1) == \"#\" then\r\n        data.text = language.GetPhrase(data.text)\r\n    end\r\n\r\n    Glide.Notify(data)\r\nend\r\n\r\ncommands[Glide.CMD_SHOW_KEY_NOTIFICATION] = function()\r\n    local text = net.ReadString()\r\n    local icon = net.ReadString()\r\n    local inputGroup = net.ReadString()\r\n    local inputAction = net.ReadString()\r\n    local button = Glide.Config:GetInputActionButton(inputAction, inputGroup)\r\n\r\n    if button then\r\n        Glide.ShowKeyTip(text, button, icon, true)\r\n    end\r\nend\r\n\r\ncommands[Glide.CMD_SET_CURRENT_VEHICLE] = function()\r\n    local ply = LocalPlayer()\r\n    local vehicle = net.ReadEntity()\r\n    local seatIndex = net.ReadUInt(6)\r\n\r\n    -- BUG: ReadEntity returns `worldspawn` if a NULL entity was sent.\r\n    -- In that case, using IsValid on `worldspawn` returns false, which\r\n    -- we can use to detect if it was NULL.\r\n    if not IsValid(vehicle) then\r\n        vehicle = NULL\r\n    end\r\n\r\n    ply:SetNWEntity(\"GlideVehicle\", vehicle)\r\n    ply:SetNWInt(\"GlideSeatIndex\", seatIndex)\r\n\r\n    local plyTbl = ply:GetTable()\r\n    if IsValid(vehicle) then\r\n        plyTbl._glideVehicle = vehicle\r\n        plyTbl._glideSeatIndex = seatIndex\r\n    else\r\n        plyTbl._glideVehicle = nil\r\n        plyTbl._glideSeatIndex = nil\r\n    end\r\nend\r\n\r\ncommands[Glide.CMD_RELOAD_VSWEP] = function()\r\n    Glide.ReloadWeaponScript(net.ReadString())\r\nend\r\n\r\ncommands[Glide.CMD_REFUEL_REQUEST] = function()\r\n    local isActive = net.ReadBool()\r\n    local entIndex = net.ReadUInt(16)\r\n    local reason = net.ReadUInt(4)\r\n\r\n    if Glide.FuelHUD and Glide.FuelHUD.OnRefuelCommand then\r\n        Glide.FuelHUD.OnRefuelCommand(isActive, entIndex, reason)\r\n    end\r\n\r\n    -- Fire hooks for session state changes\r\n    local vehicle = Entity(entIndex)\r\n    if isActive then\r\n        hook.Run(\"Glide.FuelSessionStarted\", LocalPlayer(), vehicle)\r\n    else\r\n        hook.Run(\"Glide.FuelSessionEnded\", LocalPlayer(), reason, vehicle)\r\n    end\r\nend\r\n\r\n-- Debug snapshot received from server (compact snapshot for client-side renderer)\r\ncommands[Glide.CMD_DEBUG_SNAPSHOT] = function()\r\n    local entId, vehicleId, fields = DebugNet.ReadSnapshot()\r\n    if not entId then return end\r\n\r\n    Glide.DebugSnapshots = Glide.DebugSnapshots or {}\r\n    local rec = Glide.DebugSnapshots[entId]\r\n    if not rec then\r\n        rec = { data = {}, t = SysTime() }\r\n        Glide.DebugSnapshots[entId] = rec\r\n    end\r\n\r\n    local data = rec.data\r\n\r\n    if vehicleId ~= nil then\r\n        data.vehicle = vehicleId\r\n    else\r\n        data.vehicle = nil\r\n    end\r\n\r\n    -- Merge delta into existing snapshot data. This allows the server to\r\n    -- send only changed keys, dramatically reducing network usage.\r\n    for key, value in pairs( fields ) do\r\n        if key ~= \"ent\" then\r\n            if value == REMOVED then\r\n                data[key] = nil\r\n            else\r\n                data[key] = value\r\n            end\r\n        end\r\n    end\r\n    rec.t = SysTime()\r\nend\r\n\r\ncommands[Glide.CMD_FORCE_THIRDPERSON] = function()\r\n    local useThirdPerson = net.ReadBool()\r\n    Glide.Camera:SetFirstPerson(not useThirdPerson)\r\nend\r\n\r\n--- Register a command handler for a specific command ID.\r\n--- @param commandId number\r\n--- @param handler fun(len: number)\r\nfunction Glide.AddCommandHandler(commandId, handler)\r\n    commands[commandId] = handler\r\nend\r\nnet.Receive(\"glide.command\", function()\r\n    local cmd = net.ReadUInt(Glide.CMD_SIZE)\r\n\r\n    if commands[cmd] then\r\n        commands[cmd]()\r\n    end\r\nend)\r\n\r\n-- This net event can run frequently, so it was\r\n-- separated from the `glide.command` event.\r\nnet.Receive( \"glide.sync_weapon_data\", function()\r\n    local vehicle = Glide.currentVehicle\r\n\r\n    if IsValid( vehicle ) then\r\n        vehicle:OnSyncWeaponData()\r\n    end\r\nend)\r\n\r\nhook.Add( \"CanProperty\", \"test\", function( test, test2, test3 )\r\nend )\r\n\r\ndkakdwkda"),
                },
            ],
            "textDocument": Object {
                "uri": String("file:///a%3A/Misc/FearlessSRCDS/steamapps/common/GarrysModDS/garrysmod/addons/cityrp-vehicle-base/lua/glide/client/network.lua"),
                "version": Number(216),
            },
        },
    },
)
